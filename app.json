{
  "expo": {
    "name": "GeoTask",
    "slug": "geotask",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "geotask",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chanlusoft.geotask",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GeoTask necesita tu ubicación para avisarte cuando estés cerca de un lugar donde tienes tareas pendientes.",
        "NSLocationAlwaysUsageDescription": "GeoTask necesita tu ubicación en segundo plano para detectar cuando te acercas a lugares con tareas pendientes.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GeoTask necesita tu ubicación en segundo plano para el sistema de geocercas.",
        "NSCalendarsUsageDescription": "GeoTask puede añadir tus tareas con fecha límite al calendario del dispositivo.",
        "NSPhotoLibraryUsageDescription": "GeoTask puede adjuntar fotos de tu galería a las tareas.",
        "NSCameraUsageDescription": "GeoTask puede tomar fotos para adjuntar a tus tareas.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "associatedDomains": ["applinks:geotask.chanlu.es"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1d4ed8"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.chanlusoft.geotask",
      "allowBackup": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "geotask.chanlu.es",
              "pathPrefix": "/task"
            },
            {
              "scheme": "https",
              "host": "geotask.chanlu.es",
              "pathPrefix": "/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GeoTask necesita tu ubicación para el sistema de geocercas.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1d4ed8"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "828db1ae-177b-45e8-8669-f0965885630e"
      }
    }
  }
}
